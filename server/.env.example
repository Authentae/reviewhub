NODE_ENV=development
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
CLIENT_URL=http://localhost:5173

# SQLite DB path (defaults to ./reviewhub.db)
DATABASE_PATH=./reviewhub.db

# SMTP — leave blank to use console log in dev
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ReviewHub <noreply@yourdomain.com>

# Anthropic API for AI-drafted review replies.
# Leave ANTHROPIC_API_KEY blank in development and the server will use a
# built-in mock client that produces realistic varied drafts — no credits
# burned, no key required. Set ANTHROPIC_MOCK=1 to force mock mode in any
# environment (useful for staging demos or offline work).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MOCK=

# LemonSqueezy billing (leave blank to disable billing features)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
