# ─────────────────────────────────────────────────────────────────────────────
# ReviewHub server environment configuration
#
# Copy this file to `.env` and fill in the values. Anything left blank uses
# either a sensible default or a built-in mock — see comments per section.
#
# What's REQUIRED for a real deploy: JWT_SECRET, CLIENT_URL, SMTP_*, and either
# ANTHROPIC_API_KEY or ANTHROPIC_MOCK=1. Everything else is optional.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# JWT signing secret. MUST be set in production and ≥32 chars; the auth
# middleware logs a warning + uses a dev fallback if it's missing/short.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
# Public-facing app URL. Used in email links, OAuth redirects, CORS origin,
# and anywhere the server needs to construct an absolute URL. In production
# this is the domain customers see in their inbox.
CLIENT_URL=http://localhost:5173

# Optional: alias for CLIENT_URL used by some legacy code paths.
APP_URL=

# Optional: shown in /api/health as `version`. Wire your CI to set this to
# the git SHA so you can confirm which build is live.
APP_VERSION=

# SQLite DB path. Set to `:memory:` for ephemeral runs; defaults to
# server/data/reviews.db relative to the project root.
DATABASE_PATH=

# ── Email (SMTP via Resend, SendGrid, Mailgun, etc.) ────────────────────────
# Leave SMTP_HOST blank in dev — outbound mail logs to stdout instead.
# Production: see docs at resend.com/docs for credentials. ⚠ Many PaaS
# providers (Railway, Fly free tier) BLOCK outbound port 587 — use 2587
# for Resend, 2525 for SendGrid, etc. Boot warning will tell you to switch
# if connection times out.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ReviewHub <noreply@yourdomain.com>

# ── AI drafts (Anthropic Claude) ────────────────────────────────────────────
# Leave ANTHROPIC_API_KEY blank in dev — server uses a built-in mock that
# produces realistic varied drafts at zero cost. Set ANTHROPIC_MOCK=1 to
# force mock mode anywhere (staging demos, offline work).
#
# Recommended model for review-reply use case: claude-haiku-4-5-20251001
# (~27× cheaper than Opus, quality is fine for short polite replies).
# Set a $20/mo spending cap at console.anthropic.com/settings/limits.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MOCK=
# Mock mode latency — milliseconds to wait before responding. 0 = instant.
# Default ~600ms simulates real API for demos. Tests force 0 via NODE_ENV=test.
ANTHROPIC_MOCK_LATENCY=

# ── Billing (LemonSqueezy by default) ───────────────────────────────────────
# Leave blank to disable paid plans entirely (Free tier still works).
# BILLING_PROVIDER toggles between providers; lemonsqueezy is the only one
# fully implemented, stripe/paddle stubs exist for future migration.
BILLING_PROVIDER=lemonsqueezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
# 6 variant IDs from your LS dashboard (one per Subscription product variant).
# Without these, /api/billing/checkout returns 400.
LS_VARIANT_STARTER_MONTHLY=
LS_VARIANT_STARTER_ANNUAL=
LS_VARIANT_PRO_MONTHLY=
LS_VARIANT_PRO_ANNUAL=
LS_VARIANT_BUSINESS_MONTHLY=
LS_VARIANT_BUSINESS_ANNUAL=
# Future provider stubs (not yet wired):
STRIPE_SECRET_KEY=
PADDLE_API_KEY=

# ── Admin operator email ────────────────────────────────────────────────────
# Whoever owns this email gets access to /api/admin/* (audit logs, stats,
# business-claim approvals). Whitespace-tolerant comparison.
ADMIN_EMAIL=

# ── Observability ───────────────────────────────────────────────────────────
# Sentry DSN for error forwarding. Without it, errors still log to stderr
# but no remote aggregation happens. Uses our lightweight Store-API forwarder
# (no @sentry/node dependency), so the production bundle stays slim.
SENTRY_DSN=

# Audit log retention — old security-event rows pruned at boot.
# 0 disables trimming. Default 365 days.
AUDIT_RETENTION_DAYS=365

# ── Backup scheduler ────────────────────────────────────────────────────────
# Hot-copies the SQLite DB every BACKUP_INTERVAL_HOURS into BACKUP_DIR.
# Set BACKUP_INTERVAL_HOURS=0 to disable.
BACKUP_DIR=
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
# Optional S3 destination (not yet wired — placeholder for future):
BACKUP_S3_BUCKET=
BACKUP_S3_KEY_PREFIX=

# ── Background job intervals (milliseconds) ─────────────────────────────────
# Tune to taste. Defaults are sensible for a small SaaS.
SYNC_INTERVAL_MS=900000           # 15 min — pull new reviews from connected platforms
DIGEST_INTERVAL_MS=604800000      # 7 days — weekly digest scheduler
FOLLOW_UP_INTERVAL_MS=21600000    # 6 hrs — review-request follow-up scanner

# ── Review platform integrations ────────────────────────────────────────────
# Each provider is autodetected as "configured" only when its required env
# vars are set. Without any, the mock provider produces seeded sample data
# (gated by ENABLE_MOCK_PROVIDER in production).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
YELP_API_KEY=
TRUSTPILOT_API_KEY=
TRIPADVISOR_API_KEY=
WONGNAI_API_KEY=
WONGNAI_PARTNER_ID=

# Mock provider toggle. In production it's OFF unless ENABLE_MOCK_PROVIDER=1.
# In dev it's ON unless DISABLE_MOCK_PROVIDER=1.
ENABLE_MOCK_PROVIDER=
DISABLE_MOCK_PROVIDER=

# Enable posting replies BACK to the source platform on /respond.
# Comma-separated list of provider names: e.g. "google,facebook".
# Off by default — opt-in because it requires write-scope OAuth and platform
# review-policy compliance.
REPLY_TO_PLATFORMS=

# ── Demo seeding ────────────────────────────────────────────────────────────
# Creates a "demo@reviewhub.review / demo123" user on first boot for testing.
# In production, gated behind SEED_DEMO=1 to prevent accidental seeding.
SEED_DEMO=

# ── Single-process deploy (serve SPA from same port as API) ─────────────────
# Set SERVE_CLIENT=1 to have the Node server also serve the built React app
# from CLIENT_DIST_DIR (defaults to ../client-dist). Useful for Railway /
# Fly single-service topology — one container handles both API + SPA.
SERVE_CLIENT=
CLIENT_DIST_DIR=
