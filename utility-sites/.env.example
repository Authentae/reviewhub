# Public site URL (used for canonical, OG, sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://example.com

# Google AdSense — leave blank in dev to render placeholders
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=
NEXT_PUBLIC_ADSENSE_SLOT_IN_CONTENT=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=

# Affiliate partner IDs (leave blank in dev — placeholder cards render with #)
NEXT_PUBLIC_AFFILIATE_TURBOTAX_ID=
NEXT_PUBLIC_AFFILIATE_TAXACT_ID=
NEXT_PUBLIC_AFFILIATE_HARNESS_ID=
NEXT_PUBLIC_AFFILIATE_CARTA_ID=
NEXT_PUBLIC_AFFILIATE_EMPOWER_ID=

# Analytics — pick one (or neither in dev)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Search Console verification meta token (optional)
NEXT_PUBLIC_GSC_VERIFICATION=

# Set to "1" on preview deploys to disable indexing
ROBOTS_NOINDEX=
